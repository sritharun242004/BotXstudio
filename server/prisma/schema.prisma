generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  USER
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  name         String
  passwordHash String?  @map("password_hash")
  cognitoSub   String?  @unique @map("cognito_sub")
  role         Role     @default(USER)
  permissions  Json?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  storyboards        Storyboard[]
  images             Image[]
  assets             Asset[]
  apiLogs            ApiLog[]
  adminLogs          AdminLog[]
  templates          Template[]
  disabledTemplates  DisabledTemplate[]

  @@map("users")
}

model Storyboard {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  title      String   @default("New storyboard")
  garmentType String  @default("") @map("garment_type")
  isActive   Boolean  @default(false) @map("is_active")
  previewUrl String?  @map("preview_url")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  // StoryboardConfig — 22 flat columns
  occasionPreset        String @default("") @map("occasion_preset")
  occasionDetails       String @default("") @map("occasion_details")
  accessories           String @default("") @map("accessories")
  bottomWearPreset      String @default("") @map("bottom_wear_preset")
  bottomWearDetails     String @default("") @map("bottom_wear_details")
  printInputKind        String @default("image") @map("print_input_kind")
  printColorHex         String @default("") @map("print_color_hex")
  printAdditionalPrompt String @default("") @map("print_additional_prompt")
  printTargetGender     String @default("Male") @map("print_target_gender")
  printGarmentCategory  String @default("T-shirt") @map("print_garment_category")
  footwearPreset        String @default("") @map("footwear_preset")
  footwearDetails       String @default("") @map("footwear_details")
  stylePreset           String @default("") @map("style_preset")
  styleKeywordsDetails  String @default("") @map("style_keywords_details")
  backgroundThemePreset  String @default("") @map("background_theme_preset")
  backgroundThemeDetails String @default("") @map("background_theme_details")
  modelPreset           String @default("White / European") @map("model_preset")
  modelDetails          String @default("") @map("model_details")
  modelPosePreset       String @default("") @map("model_pose_preset")
  modelPoseDetails      String @default("") @map("model_pose_details")
  modelStylingPreset    String @default("") @map("model_styling_preset")
  modelStylingNotes     String @default("") @map("model_styling_notes")

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  images Image[]

  @@map("storyboards")
}

model Image {
  id              String   @id @default(uuid())
  userId          String   @map("user_id")
  storyboardId    String?  @map("storyboard_id")
  title           String
  kind            String
  mimeType        String   @map("mime_type")
  fileName        String?  @map("file_name")
  s3Key           String   @map("s3_key")
  s3Bucket        String   @map("s3_bucket")
  fileSizeBytes   Int?     @map("file_size_bytes")
  storyboardTitle String?  @map("storyboard_title")
  createdAt       DateTime @default(now()) @map("created_at")

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  storyboard Storyboard? @relation(fields: [storyboardId], references: [id], onDelete: SetNull)

  @@map("images")
}

model Asset {
  id            String   @id @default(uuid())
  userId        String   @map("user_id")
  kind          String
  title         String
  mimeType      String   @map("mime_type")
  s3Key         String   @map("s3_key")
  s3Bucket      String   @map("s3_bucket")
  fileSizeBytes Int?     @map("file_size_bytes")
  createdAt     DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("assets")
}

model ApiLog {
  id            String   @id @default(uuid())
  userId        String   @map("user_id")
  type          String
  model         String
  promptTokens  Int      @default(0) @map("prompt_tokens")
  outputTokens  Int      @default(0) @map("output_tokens")
  totalTokens   Int      @default(0) @map("total_tokens")
  latencyMs     Int      @default(0) @map("latency_ms")
  status        String   @default("success")
  errorMessage  String?  @map("error_message")
  createdAt     DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("api_logs")
}

model AdminLog {
  id        String   @id @default(uuid())
  adminId   String   @map("admin_id")
  action    String
  targetId  String?  @map("target_id")
  details   Json?
  createdAt DateTime @default(now()) @map("created_at")

  admin User @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@map("admin_logs")
}

model SystemConfig {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("system_config")
}

model Template {
  id         String   @id @default(uuid())
  title      String
  category   String
  s3Key      String   @map("s3_key")
  s3Bucket   String   @map("s3_bucket")
  previewUrl String?  @map("preview_url")
  metadata   Json?
  createdBy  String   @map("created_by")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  createdByUser User @relation(fields: [createdBy], references: [id], onDelete: Cascade)

  @@map("templates")
}

model DisabledTemplate {
  id          String   @id @default(uuid())
  templateId  String   @unique @map("template_id")
  category    String
  disabledAt  DateTime @default(now()) @map("disabled_at")
  disabledBy  String   @map("disabled_by")

  disabledByUser User @relation(fields: [disabledBy], references: [id], onDelete: Cascade)

  @@map("disabled_templates")
}
